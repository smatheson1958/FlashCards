      <sentence>
         <text>CR</text>
         <clip></clip>
      </sentence>
      <sentence>
         <text>"What's that?", said Dylan.</text>
         <clip>uk/assets/sound/whiteSpace.mp3</clip>    
      </sentence>
      <sentence>
         <text>CR</text>
         <clip></clip>
      </sentence>
      <sentence>
         <text>CR</text>
         <clip></clip>
      </sentence>
      <sentence>
         <text>"I don’t know," said Cole, grabbing a stick.</text>
         <clip>uk/assets/sound/whiteSpace.mp3</clip>
      </sentence>
      <sentence>
         <text>"But you go out that way and I’ll go this way and we can find out."</text>
         <clip>uk/assets/sound/whiteSpace.mp3</clip>
      </sentence>
   </paragraph>
   <paragraph>
       <sentence>
