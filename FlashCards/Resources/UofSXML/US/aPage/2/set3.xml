      <sentence>
         <text>A ranch can be hundreds of miles wide.</text>
         <clip>uk/assets/sound/whiteSpace.mp3</clip>
      </sentence>
      <sentence>
         <text>It lets the cattle roam and feed across the land.</text>
         <clip>uk/assets/sound/whiteSpace.mp3</clip>
